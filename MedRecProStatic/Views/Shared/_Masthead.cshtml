@using MedRecPro.Static.Models
@*
    Shared site masthead (navbar). Single source of truth for the brand and
    primary navigation, used by both _Layout.cshtml and the self-contained
    Home/Chat.cshtml so every server-rendered surface shares one masthead.

    Optional, set via ViewData in the calling view before rendering:
      ViewData["MastheadSubtitle"]  string  - context label after the brand
                                              (e.g., "AI Assistant").
      ViewData["MastheadActions"]   string  - trusted raw HTML for page-specific
                                              actions (e.g., the Chat "Clear"
                                              button) appended to the nav menu.

    Styling lives in ~/css/masthead.css, which both hosts link.
*@
@{
    var config = ViewBag.Config as SiteConfig ?? new SiteConfig { SiteName = "MedRecPro" };
    var mastheadSubtitle = ViewData["MastheadSubtitle"] as string;
    var mastheadActions = ViewData["MastheadActions"] as string;
}
<header>
    <nav class="navbar">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <span class="navbar-logo">
                    <svg viewBox="0 0 95.11 71.96" xmlns="http://www.w3.org/2000/svg">
                        <path d="M0,8l.03,63.93h14.15l-.09-71.93h-6.09C3.58,0,0,3.58,0,8Z" fill="#5a3d2c" />
                        <polygon points="7.87 0 25.91 71.93 41.06 71.93 22.96 0 7.87 0" fill="#5a3d2c" />
                        <polygon points="29.39 0 47.43 71.93 62.58 71.93 44.49 0 29.39 0" fill="#5a3d2c" />
                        <path d="M51.22.03l18.04,71.93h4.89c5.21,0,9.03-4.9,7.76-9.95L66.31.03h-15.09Z" fill="#f4a126" />
                        <path d="M95.11,27.68h-15.07L73.1.03h8.85c3.67,0,6.87,2.5,7.76,6.06l5.4,21.6Z" fill="#f4a126" />
                    </svg>
                </span>
                @config.SiteName
            </a>
            @if (!string.IsNullOrEmpty(mastheadSubtitle))
            {
                <span class="navbar-subtitle">@mastheadSubtitle</span>
            }
            @* Mobile hamburger toggle. Hidden on desktop via masthead.css;
               revealed at <=768px where it toggles the .navbar.is-open state
               wired by the inline script below. *@
            <button type="button" class="navbar-toggle"
                    aria-label="Toggle navigation menu"
                    aria-expanded="false"
                    aria-controls="navbar-menu">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round"
                     stroke-linejoin="round" viewBox="0 0 24 24" aria-hidden="true">
                    <line x1="3" y1="6" x2="21" y2="6" />
                    <line x1="3" y1="12" x2="21" y2="12" />
                    <line x1="3" y1="18" x2="21" y2="18" />
                </svg>
            </button>
            <div class="navbar-menu" id="navbar-menu">
                <a asp-controller="Home" asp-action="Index">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" style="margin-bottom: -1px;">
                        <path d="M8.354 1.146a.5.5 0 0 0-.708 0l-6 6A.5.5 0 0 0 1.5 7.5v7a.5.5 0 0 0 .5.5h4.5a.5.5 0 0 0 .5-.5v-4h2v4a.5.5 0 0 0 .5.5H14a.5.5 0 0 0 .5-.5v-7a.5.5 0 0 0-.146-.354L13 5.793V2.5a.5.5 0 0 0-.5-.5h-1a.5.5 0 0 0-.5.5v1.293L8.354 1.146ZM2.5 14V7.707l5.5-5.5 5.5 5.5V14H10v-4a.5.5 0 0 0-.5-.5h-3a.5.5 0 0 0-.5.5v4H2.5Z" />
                    </svg>
                    Home
                </a>
                <a asp-controller="Home" asp-action="Chat">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M7.657 6.247c.11-.33.576-.33.686 0l.645 1.937a2.89 2.89 0 0 0 1.828 1.828l1.937.645c.33.11.33.576 0 .686l-1.937.645a2.89 2.89 0 0 0-1.828 1.828l-.645 1.937a.361.361 0 0 1-.686 0l-.645-1.937a2.89 2.89 0 0 0-1.828-1.828l-1.937-.645a.361.361 0 0 1 0-.686l1.937-.645a2.89 2.89 0 0 0 1.828-1.828l.645-1.937zM3.794 1.148a.217.217 0 0 1 .412 0l.387 1.162c.173.518.579.924 1.097 1.097l1.162.387a.217.217 0 0 1 0 .412l-1.162.387A1.734 1.734 0 0 0 4.593 5.69l-.387 1.162a.217.217 0 0 1-.412 0L3.407 5.69a1.734 1.734 0 0 0-1.097-1.097l-1.162-.387a.217.217 0 0 1 0-.412l1.162-.387A1.734 1.734 0 0 0 3.407 2.31l.387-1.162zM10.863.099a.145.145 0 0 1 .274 0l.258.774c.115.346.386.617.732.732l.774.258a.145.145 0 0 1 0 .274l-.774.258a1.156 1.156 0 0 0-.732.732l-.258.774a.145.145 0 0 1-.274 0l-.258-.774a1.156 1.156 0 0 0-.732-.732L9.1 2.137a.145.145 0 0 1 0-.274l.774-.258c.346-.115.617-.386.732-.732L10.863.1z" />
                    </svg>
                    AI
                </a>
                <a asp-controller="Home" asp-action="McpDocs">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" style="margin-bottom: -1px;">
                        <path d="M2 2a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2zm2-1a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1H4z" />
                        <path d="M9.5 3.5v-2l3 3h-2a1 1 0 0 1-1-1zM4.5 9a.5.5 0 0 1 0-1h7a.5.5 0 0 1 0 1h-7zM4 10.5a.5.5 0 0 1 .5-.5h7a.5.5 0 0 1 0 1h-7a.5.5 0 0 1-.5-.5zm.5 2.5a.5.5 0 0 1 0-1h4a.5.5 0 0 1 0 1h-4z" />
                    </svg>
                    MCP
                </a>
                <a href="@config.SwaggerUrl">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" style="margin-bottom: -1px;">
                        <path d="M1 2.828c.885-.37 2.154-.769 3.388-.893 1.33-.134 2.458.063 3.112.752v9.746c-.935-.53-2.12-.603-3.213-.493-1.18.12-2.37.461-3.287.811V2.828zm7.5-.141c.654-.689 1.782-.886 3.112-.752 1.234.124 2.503.523 3.388.893v9.923c-.918-.35-2.107-.692-3.287-.81-1.094-.111-2.278-.039-3.213.492V2.687zM8 1.783C7.015.936 5.587.81 4.287.94c-1.514.153-3.042.672-3.994 1.105A.5.5 0 0 0 0 2.5v11a.5.5 0 0 0 .707.455c.882-.4 2.303-.881 3.68-1.02 1.409-.142 2.59.087 3.223.877a.5.5 0 0 0 .78 0c.633-.79 1.814-1.019 3.222-.877 1.378.139 2.8.62 3.681 1.02A.5.5 0 0 0 16 13.5v-11a.5.5 0 0 0-.293-.455c-.952-.433-2.48-.952-3.994-1.105C10.413.809 8.985.936 8 1.783z" />
                    </svg>
                    API Docs
                </a>
                @if (!string.IsNullOrEmpty(mastheadActions))
                {
                    @Html.Raw(mastheadActions)
                }
            </div>
        </div>
    </nav>
</header>
@*
    Self-contained mobile nav toggle. Lives in the partial (not site.js) so it
    runs on every host that renders the masthead — including Home/Chat, which is
    Layout=null and never loads site.js. Placed after the markup so the elements
    already exist; the IIFE + data-toggle-bound guard make it safe if the
    partial ever renders twice.
*@
<script>
    (function () {
        document.querySelectorAll('.navbar').forEach(function (navbar) {
            if (navbar.dataset.toggleBound === '1') return;
            var toggle = navbar.querySelector('.navbar-toggle');
            var menu = navbar.querySelector('.navbar-menu');
            if (!toggle || !menu) return;
            navbar.dataset.toggleBound = '1';

            function setOpen(open) {
                navbar.classList.toggle('is-open', open);
                toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
            }

            toggle.addEventListener('click', function () {
                setOpen(!navbar.classList.contains('is-open'));
            });

            // Close after tapping any link or action button in the panel.
            menu.addEventListener('click', function (e) {
                if (e.target.closest('a, .navbar-action')) setOpen(false);
            });

            // Close on Escape.
            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape') setOpen(false);
            });

            // Reset to closed when returning to desktop width.
            window.addEventListener('resize', function () {
                if (window.innerWidth > 768) setOpen(false);
            });
        });
    })();
</script>
